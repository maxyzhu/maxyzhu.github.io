---
import Layout from "../layouts/Layout.astro";

const projects = [
  {
    title: "Affordable Housing, Bellevue",
    tags: ["Architecture"],
    year: "2023",
    description: "Mixed-use affordable housing development.",
  },
  {
    title: "involveMINT Wallet UI",
    tags: ["Software"],
    year: "2025",
    description: "Venmo-style wallet interface with Framer Motion animations.",
  },
  {
    title: "AI-Augmented Design Pipeline",
    tags: ["Architecture", "Software"],
    year: "2025",
    description:
      "Multi-agent LLM pipeline replacing traditional architecture workflows.",
  },
];
---

<Layout title="Home">
  <section class="hero">
    <h1>
      Architect.<br />Engineer.<br />Builder of both.
    </h1>
  </section>

  <section class="recent-work">
    <div class="section-header">
      <span class="section-label">Recent Work</span>
      <a href="/atelier" class="see-all">See all →</a>
    </div>
    <div class="scroll-row">
      {
        projects.map((p) => (
          <div class="scroll-card">
            <div class="card-header">
              <span class="year">{p.year}</span>
              <div class="tags">
                {p.tags.map((t) => (
                  <span class="tag">{t}</span>
                ))}
              </div>
            </div>
            <h3>{p.title}</h3>
            <p>{p.description}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="hero">
    <p>Ask me anything.</p>
  </section>

  <div class="chat-placeholder">
    <iframe
      src="https://mingxizhu-personal-chatbot.hf.space"
      style="width: 100%; height: 500px; border: none;"
    >
    </iframe>
  </div>
</Layout>

<style>
  .hero {
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 5rem);
    font-weight: normal;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: var(--color-accent);
  }

  p {
    font-size: 1.1rem;
    color: var(--color-muted);
  }

  /* Recent Work */
  .recent-work {
    margin-bottom: 3rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .section-label {
    font-size: 0.85rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .see-all {
    font-size: 0.85rem;
    color: var(--color-accent);
    text-decoration: none;
  }

  .see-all:hover {
    text-decoration: underline;
  }

  .scroll-row {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    scrollbar-width: none;
  }

  .scroll-row::-webkit-scrollbar {
    display: none;
  }

  .scroll-card {
    flex: 0 0 280px;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.25rem;
    transition: border-color 0.2s;
    cursor: pointer;
  }

  .scroll-card:hover {
    border-color: var(--color-accent);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .year {
    font-size: 0.8rem;
    color: var(--color-hint);
  }

  .tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    background: var(--color-bg);
    color: var(--color-muted);
    border: 1px solid var(--color-border);
  }

  .scroll-card h3 {
    font-size: 1rem;
    font-weight: normal;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .scroll-card p {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .chat-placeholder {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-hint);
  }
</style>
