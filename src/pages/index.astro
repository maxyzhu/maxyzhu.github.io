---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Home">
	<section class="hero">
		<h1>Architect.<br />Engineer.<br />Builder of both.</h1>
		<p>Ask me anything.</p>
	</section>
	<div class="chat-placeholder">
		<!-- ChatBot component goes here -->
		<p>Chat coming soon</p>
	</div>
</Layout>

<style>
	.hero {
		margin-bottom: 3rem;
	}

	h1 {
		font-size: clamp(2.5rem, 6vw, 5rem);
		font-weight: normal;
		line-height: 1.15;
		letter-spacing: -0.02em;
		margin-bottom: 1.5rem;
	}

	p {
		font-size: 1.1rem;
		color: var(--color-muted);
	}

	.chat-placeholder {
		border: 1px solid var(--color-border);
		border-radius: 12px;
		padding: 2rem;
		min-height: 400px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-hint);
	}
</style>
